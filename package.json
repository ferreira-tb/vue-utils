{
  "name": "@tb-dev/vue",
  "version": "4.0.17",
  "description": "Vue utilities",
  "license": "MIT",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "funding": "https://github.com/sponsors/ferreira-tb",
  "author": {
    "name": "Andrew Ferreira",
    "email": "andrew.shien2@gmail.com",
    "url": "https://github.com/ferreira-tb"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferreira-tb/vue-utils.git"
  },
  "bugs": {
    "url": "https://github.com/ferreira-tb/vue-utils/issues"
  },
  "keywords": [
    "vue",
    "utils",
    "composables"
  ],
  "scripts": {
    "build": "vite build",
    "docs": "typedoc --plugin typedoc-plugin-mdn-links",
    "format": "dprint fmt",
    "lint": "eslint . --config eslint.config.js",
    "release": "pnpm run build && pnpm publish",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tb-dev/utils": "^7.3.15",
    "@vueuse/core": "^14.2.1",
    "es-toolkit": "^1.45.1",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tb-dev/eslint-config": "^9.1.4",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
